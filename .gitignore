# ==========================================
# Root .gitignore for Blind-Match Engine
# ==========================================

# --- System & OS Files ---
.DS_Store
Thumbs.db
*.log

# --- IDE & Editors ---
.vscode/
.idea/
*.swp
*.swo

# --- Environment & Secrets (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Ignore the Firebase private key everywhere
**/serviceAccountKey.json
# Ignore any other json keys
*.key.json

# --- Backend (Python / FastAPI) ---
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/venv/
**/env/
**/ENV/
**/.venv/
**/backend/uploads/
**/backend/static/
# Ignore torch/model weights if downloaded locally
**/*.pt
**/*.pth

# --- Frontend (Node / React) ---
**/node_modules/
**/frontend/build/
**/frontend/dist/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# --- Testing ---
**/coverage/